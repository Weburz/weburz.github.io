# Force LF line endings across platforms.
* text=auto eol=lf

# Lockfiles are noisy in diffs and never reviewed line-by-line.
pnpm-lock.yaml -diff linguist-generated=true

# Binary asset types — never treat as text.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary
