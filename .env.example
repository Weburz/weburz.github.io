# Environment variables consumed by the build. Copy to `.env` to use locally;
# CI sets these from `.github/workflows/deploy.yml` (NUXT_PUBLIC_SITE_URL) and
# the repo's Actions variables (NUXT_PUBLIC_UMAMI_WEBSITE_ID).
#
# All vars here are NUXT_PUBLIC_* — they get baked into the static build and
# ship in the page HTML, so none of them are secret.

# ---- Site URL -------------------------------------------------------------
# Used by nuxt-site-config / nuxt-og-image / RSS feed. Should match the live
# canonical URL — defaults to the live domain in production.
NUXT_PUBLIC_SITE_URL=https://tech.weburz.com

# ---- Umami analytics ------------------------------------------------------
# Self-hosted Umami at https://umami.weburz.com — paste the website UUID from
# the Umami dashboard (Settings → Websites → [site] → Tracking code).
# Leave blank to disable analytics (the plugin no-ops when unset).
NUXT_PUBLIC_UMAMI_WEBSITE_ID=
